# Filament — Environment Configuration
# All RPC URLs are user-supplied. Missing entries are tolerated (chain is skipped).
RPC_ETHEREUM=                         # HTTPS RPC endpoint for Ethereum mainnet
RPC_ARBITRUM=                         # HTTPS RPC endpoint for Arbitrum One
RPC_OPTIMISM=                         # HTTPS RPC endpoint for Optimism
RPC_BASE=                             # HTTPS RPC endpoint for Base
RPC_MANTLE=                           # HTTPS RPC endpoint for Mantle
RPC_POLYGON=                          # HTTPS RPC endpoint for Polygon PoS
RPC_BNB=                              # HTTPS RPC endpoint for BNB Smart Chain

# Operational tuning
RATE_LIMIT_MS=200                     # Minimum delay between outbound RPC calls
MAX_GRAPH_DEPTH=3                     # Hard cap on BFS hop count
CACHE_TTL_SECONDS=300                 # TTL for the in-memory response cache

# Transport selection
MCP_TRANSPORT=sse                     # "stdio" (default) or "sse"
PORT=3008                             # HTTP port used when MCP_TRANSPORT=sse
